+import os
+import tkinter as tk
+from tkinter import ttk, filedialog, messagebox
+import customtkinter as ctk
+
+from src.extractor import extract_booking_data
+from src.exporter import export_to_excel
+
+# Set appearance mode and color theme
+ctk.set_appearance_mode("System")
+ctk.set_default_color_theme("blue")
+
+class App(ctk.CTk):
+    def __init__(self):
+        super().__init__()
+
+        self.title("Auto Read PDF Booking")
+        self.geometry("1000x600")
+
+        self.pdf_files = []
+        self.extracted_data = []
+        self.display_data = [] # List of dicts for Treeview and Export
+
+        self.all_columns = [
+            "STT",
+            "Tên file PDF",
+            "Booking No",
+            "Place of Delivery",
+            "T/S Port",
+            "Equipment Pick up City",
+            "Empty Pick Up CY",
+            "Full retrurn CY",
+            "Port Cargo Cut-off",
+            "Vessel",
+            "ETD"
+        ]
+
+        # Config grid
+        self.grid_columnconfigure(1, weight=1)
+        self.grid_rowconfigure(0, weight=1)
+
+        # --- Sidebar ---
+        self.sidebar_frame = ctk.CTkFrame(self, width=200, corner_radius=0)
+        self.sidebar_frame.grid(row=0, column=0, sticky="nsew")
+        self.sidebar_frame.grid_rowconfigure(2, weight=1)
+
+        self.logo_label = ctk.CTkLabel(self.sidebar_frame, text="Auto Read PDF", font=ctk.CTkFont(size=20, weight="bold"))
+        self.logo_label.grid(row=0, column=0, padx=20, pady=(20, 10))
+
+        self.select_pdf_btn = ctk.CTkButton(self.sidebar_frame, text="Select PDFs", command=self.select_pdfs)
+        self.select_pdf_btn.grid(row=1, column=0, padx=20, pady=10)
+
+        # Checkboxes for columns
+        self.checkbox_frame = ctk.CTkScrollableFrame(self.sidebar_frame, label_text="Columns")
+        self.checkbox_frame.grid(row=2, column=0, padx=10, pady=10, sticky="nsew")
+        
+        self.column_vars = {}
+        for idx, col in enumerate(self.all_columns):
+            var = ctk.BooleanVar(value=True)
+            cb = ctk.CTkCheckBox(self.checkbox_frame, text=col, variable=var, command=self.update_treeview_columns)
+            cb.grid(row=idx, column=0, padx=10, pady=5, sticky="w")
+            self.column_vars[col] = var
+
+        self.export_btn = ctk.CTkButton(self.sidebar_frame, text="Export to Excel", command=self.export_excel)
+        self.export_btn.grid(row=3, column=0, padx=20, pady=(10, 20))
+
+        # --- Main Frame ---
+        self.main_frame = ctk.CTkFrame(self)
+        self.main_frame.grid(row=0, column=1, sticky="nsew", padx=10, pady=10)
+        self.main_frame.grid_rowconfigure(0, weight=1)
+        self.main_frame.grid_columnconfigure(0, weight=1)
+
+        # Treeview
+        # Use ttk.Treeview since customtkinter doesn't have a built-in table yet
+        style = ttk.Style()
+        style.theme_use("default")
+        style.configure("Treeview", rowheight=25)
+        
+        self.tree_scroll_y = ttk.Scrollbar(self.main_frame)
+        self.tree_scroll_y.pack(side="right", fill="y")
+        
+        self.tree_scroll_x = ttk.Scrollbar(self.main_frame, orient="horizontal")
+        self.tree_scroll_x.pack(side="bottom", fill="x")
+
+        self.tree = ttk.Treeview(
+            self.main_frame, 
+            yscrollcommand=self.tree_scroll_y.set, 
+            xscrollcommand=self.tree_scroll_x.set,
+            show="headings"
+        )
+        self.tree.pack(fill="both", expand=True)
+
+        self.tree_scroll_y.config(command=self.tree.yview)
+        self.tree_scroll_x.config(command=self.tree.xview)
+
+        self.update_treeview_columns()
+
+    def update_treeview_columns(self):
+        # Get selected columns
+        selected_cols = [col for col, var in self.column_vars.items() if var.get()]
+        
+        self.tree["columns"] = selected_cols
+        for col in selected_cols:
+            self.tree.heading(col, text=col)
+            self.tree.column(col, width=120, minwidth=100)
+            
+        self.populate_treeview()
+
+    def select_pdfs(self):
+        file_paths = filedialog.askopenfilenames(
+            title="Select PDF files",
+            filetypes=[("PDF files", "*.pdf")]
+        )
+        if file_paths:
+            self.pdf_files = list(file_paths)
+            self.process_pdfs()
+
+    def process_pdfs(self):
+        self.extracted_data = []
+        self.display_data = []
+        
+        for idx, pdf_path in enumerate(self.pdf_files, 1):
+            try:
+                data = extract_booking_data(pdf_path)
+                
+                # Resolve Vessel and ETD per business rule
+                vessel = data.get("Pre Carrier", "")
+                etd = data.get("ETD_Pre", "")
+                
+                if not vessel:
+                    vessel = data.get("Trunk Vessel", "")
+                    etd = data.get("ETD_Trunk", "")
+                    
+                display_row = {
+                    "STT": str(idx),
+                    "Tên file PDF": data.get("Tên file PDF", ""),
+                    "Booking No": data.get("Booking No", ""),
+                    "Place of Delivery": data.get("Place of Delivery", ""),
+                    "T/S Port": data.get("T/S Port", ""),
+                    "Equipment Pick up City": data.get("Equipment Pick up City", ""),
+                    "Empty Pick Up CY": data.get("Empty Pick Up CY", ""),
+                    "Full retrurn CY": data.get("Full retrurn CY", ""),
+                    "Port Cargo Cut-off": data.get("Port Cargo Cut-off", ""),
+                    "Vessel": vessel,
+                    "ETD": etd
+                }
+                
+                self.extracted_data.append(data)
+                self.display_data.append(display_row)
+            except Exception as e:
+                print(f"Failed to process {pdf_path}: {e}")
+                
+        self.populate_treeview()
+
+    def populate_treeview(self):
+        # Clear current items
+        for item in self.tree.get_children():
+            self.tree.delete(item)
+            
+        selected_cols = [col for col, var in self.column_vars.items() if var.get()]
+        
+        for row_data in self.display_data:
+            values = [row_data.get(col, "") for col in selected_cols]
+            self.tree.insert("", "end", values=values)
+
+    def export_excel(self):
+        if not self.display_data:
+            messagebox.showwarning("Warning", "No data to export. Please select PDFs first.")
+            return
+            
+        save_path = filedialog.asksaveasfilename(
+            defaultextension=".xlsx",
+            filetypes=[("Excel files", "*.xlsx")],
+            title="Save Excel File"
+        )
+        
+        if save_path:
+            selected_cols = [col for col, var in self.column_vars.items() if var.get()]
+            try:
+                success = export_to_excel(self.display_data, save_path, selected_cols)
+                if success:
+                    messagebox.showinfo("Success", f"Data exported successfully to {save_path}")
+                else:
+                    messagebox.showerror("Error", "Failed to export data.")
+            except Exception as e:
+                messagebox.showerror("Error", f"An error occurred: {e}")
+
+if __name__ == "__main__":
+    app = App()
+    app.mainloop()
